<h1><%= @snippet.title %></h1>

<div class="bg-white p-6 rounded-lg shadow">
  <p><strong>User:</strong> <%= @snippet.user.name %></p>
  <p><strong>Language:</strong> <%= @snippet.language %></p>
  <p><strong>Description:</strong> <%= @snippet.description %></p>
  <p><strong>Code:</strong></p>
  <pre class="bg-gray-100 p-4 rounded"><code><%= @snippet.code %></code></pre>
  <div class="mt-4">
    <%= link_to 'Edit', edit_admin_snippet_path(@snippet), class: "bg-blue-500 text-white px-4 py-2 rounded mr-2" %>
    <%= button_to 'Delete', admin_snippet_path(@snippet), method: :delete, data: { confirm: 'Are you sure?' }, class: "bg-red-500 text-white px-4 py-2 rounded mr-2" %>
    <%= link_to 'Back to Snippets', admin_snippets_path, class: "bg-gray-500 text-white px-4 py-2 rounded" %>
  </div>
</div>