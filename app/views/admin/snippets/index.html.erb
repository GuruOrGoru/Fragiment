<h1>Snippets</h1>

<div class="bg-white p-6 rounded-lg shadow">
  <table class="min-w-full table-auto">
    <thead>
      <tr class="bg-gray-50">
        <th class="px-4 py-2 text-left">Title</th>
        <th class="px-4 py-2 text-left">User</th>
        <th class="px-4 py-2 text-left">Language</th>
        <th class="px-4 py-2 text-left">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @snippets.each do |snippet| %>
        <tr class="border-t">
          <td class="px-4 py-2"><%= snippet.title %></td>
          <td class="px-4 py-2"><%= snippet.user.name %></td>
          <td class="px-4 py-2"><%= snippet.language %></td>
          <td class="px-4 py-2">
            <%= link_to 'Show', admin_snippet_path(snippet), class: "text-blue-600 hover:text-blue-800 mr-2" %>
            <%= link_to 'Edit', edit_admin_snippet_path(snippet), class: "text-green-600 hover:text-green-800 mr-2" %>
            <%= button_to 'Delete', admin_snippet_path(snippet), method: :delete, data: { confirm: 'Are you sure?' }, class: "bg-red-500 text-white px-2 py-1 rounded" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>