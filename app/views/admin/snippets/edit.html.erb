<h1>Edit Snippet: <%= @snippet.title %></h1>

<div class="bg-white p-6 rounded-lg shadow">
  <%= form_for @snippet, url: admin_snippet_path(@snippet), method: :patch, multipart: true do |f| %>
    <div class="mb-4">
      <%= f.label :title, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :title, class: "w-full p-2 border border-gray-300 rounded-md" %>
    </div>

    <div class="mb-4">
      <%= f.label :language, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :language, class: "w-full p-2 border border-gray-300 rounded-md" %>
    </div>

    <div class="mb-4">
      <%= f.label :description, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_area :description, rows: 3, class: "w-full p-2 border border-gray-300 rounded-md" %>
    </div>

    <div class="mb-4">
      <%= f.label :code, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_area :code, rows: 10, class: "w-full p-2 border border-gray-300 rounded-md font-mono" %>
    </div>

    <div class="mb-4">
      <%= f.label :user_id, class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :user_id, User.all.collect { |u| [u.name, u.id] }, class: "w-full p-2 border border-gray-300 rounded-md" %>
    </div>

    <div class="mb-4">
      <%= f.label :tag_list, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :tag_list, class: "w-full p-2 border border-gray-300 rounded-md" %>
    </div>

    <div class="mb-4">
      <%= f.label :images, class: "block text-sm font-medium text-gray-700" %>
      <%= f.file_field :images, multiple: true, accept: "image/png,image/jpeg,image/gif,image/webp", class: "w-full p-2 border border-gray-300 rounded-md" %>
    </div>

    <div class="flex space-x-4">
      <%= f.submit "Update Snippet", class: "bg-blue-500 text-white px-4 py-2 rounded" %>
      <%= link_to 'Cancel', admin_snippet_path(@snippet), class: "bg-gray-500 text-white px-4 py-2 rounded" %>
    </div>
  <% end %>
</div>