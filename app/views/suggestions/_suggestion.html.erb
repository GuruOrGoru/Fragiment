<div class="bg-white border border-gray-200 rounded-lg p-4 shadow-sm <%= 'ml-8' if suggestion.response_to_id %>" data-suggestion-id="<%= suggestion.id %>">
  <div class="flex items-start space-x-3">
     <% if suggestion.user.avatar.attached? %>
       <% if suggestion.user.avatar.content_type == 'image/svg+xml' %>
         <div class="w-10 h-10 rounded-full border-2 border-gray-200 overflow-hidden">
           <object data="<%= url_for(suggestion.user.avatar) %>" type="image/svg+xml" class="w-full h-full"></object>
         </div>
       <% else %>
         <%= image_tag suggestion.user.avatar.variant(:thumb), class: "w-10 h-10 rounded-full object-cover border-2 border-gray-200" %>
       <% end %>
    <% else %>
      <div class="w-10 h-10 bg-gradient-to-br from-blue-400 to-blue-600 rounded-full flex items-center justify-center border-2 border-gray-200">
        <span class="text-sm font-bold text-white"><%= suggestion.user.name[0].upcase %></span>
      </div>
    <% end %>
    <div class="flex-1">
      <div class="flex items-center space-x-2 mb-2">
        <span class="font-semibold text-gray-900"><%= link_to suggestion.user.name, user_path(suggestion.user), class: "hover:text-blue-600 transition-colors" %></span>
        <span class="text-sm text-gray-500">·</span>
        <span class="text-sm text-gray-500"><%= time_ago_in_words(suggestion.created_at) %> ago</span>
        <span class="text-xs bg-blue-100 text-blue-800 px-2 py-1 rounded-full font-medium"><%= suggestion.suggestion_type.humanize %></span>
        <span class="text-xs bg-gray-100 text-gray-800 px-2 py-1 rounded-full font-medium"><%= suggestion.status.humanize %></span>
        <% if defined?(current_user) && current_user && suggestion.user == current_user %>
          <button class="delete-suggestion-btn text-red-500 hover:text-red-700 text-sm ml-auto transition-colors" data-url="<%= snippet_suggestion_path(suggestion.snippet, suggestion) %>" data-method="delete" data-confirm="Are you sure?">
            <i class="fas fa-trash"></i>
          </button>
        <% end %>
      </div>
      <p class="text-gray-700 mb-3 leading-relaxed"><%= suggestion.content %></p>
      <div class="flex flex-wrap items-center gap-3">
        <% if defined?(current_user) && current_user %>
          <% working_vote = current_user.suggestion_votes.find_by(suggestion: suggestion, vote_type: 'working') %>
          <% broken_vote = current_user.suggestion_votes.find_by(suggestion: suggestion, vote_type: 'broken') %>
          <% implemented_vote = current_user.suggestion_votes.find_by(suggestion: suggestion, vote_type: 'implemented') %>
          <% not_working_vote = current_user.suggestion_votes.find_by(suggestion: suggestion, vote_type: 'not_working') %>
          <% if working_vote %>
            <button class="suggestion-vote-btn flex items-center space-x-1 bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-sm font-medium transition-colors" data-suggestion-id="<%= suggestion.id %>" data-voted="true" data-url="<%= snippet_suggestion_unvote_path(snippet, suggestion) %>" data-method="delete">
              <i class="fas fa-thumbs-up"></i>
              <span>Working (<%= suggestion.suggestion_votes.where(vote_type: 'working').count %>)</span>
            </button>
          <% else %>
            <%= link_to snippet_suggestion_vote_working_path(snippet, suggestion), method: :post, class: "suggestion-vote-btn flex items-center space-x-1 bg-gray-100 hover:bg-blue-100 text-gray-700 hover:text-blue-700 px-3 py-1 rounded-full text-sm font-medium transition-colors", data: { url: snippet_suggestion_vote_working_path(snippet, suggestion), method: 'post', suggestion_id: suggestion.id } do %>
              <i class="far fa-thumbs-up"></i>
              <span>Working (<%= suggestion.suggestion_votes.where(vote_type: 'working').count %>)</span>
            <% end %>
          <% end %>
          <% if broken_vote %>
            <button class="suggestion-vote-btn flex items-center space-x-1 bg-orange-100 text-orange-700 px-3 py-1 rounded-full text-sm font-medium transition-colors" data-suggestion-id="<%= suggestion.id %>" data-voted="true" data-url="<%= snippet_suggestion_unvote_path(snippet, suggestion) %>" data-method="delete">
              <i class="fas fa-exclamation-triangle"></i>
              <span>Broken (<%= suggestion.suggestion_votes.where(vote_type: 'broken').count %>)</span>
            </button>
          <% else %>
            <%= link_to snippet_suggestion_vote_broken_path(snippet, suggestion), method: :post, class: "suggestion-vote-btn flex items-center space-x-1 bg-gray-100 hover:bg-orange-100 text-gray-700 hover:text-orange-700 px-3 py-1 rounded-full text-sm font-medium transition-colors", data: { url: snippet_suggestion_vote_broken_path(snippet, suggestion), method: 'post', suggestion_id: suggestion.id } do %>
              <i class="far fa-exclamation-triangle"></i>
              <span>Broken (<%= suggestion.suggestion_votes.where(vote_type: 'broken').count %>)</span>
            <% end %>
          <% end %>
          <% if implemented_vote %>
            <button class="suggestion-vote-btn flex items-center space-x-1 bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm font-medium transition-colors" data-suggestion-id="<%= suggestion.id %>" data-voted="true" data-url="<%= snippet_suggestion_unvote_path(snippet, suggestion) %>" data-method="delete">
              <i class="fas fa-check"></i>
              <span>Implemented (<%= suggestion.suggestion_votes.where(vote_type: 'implemented').count %>)</span>
            </button>
          <% else %>
            <%= link_to snippet_suggestion_vote_implemented_path(snippet, suggestion), method: :post, class: "suggestion-vote-btn text-gray-500 hover:text-green-500 px-3 py-1 rounded-full text-sm font-medium transition-colors", data: { url: snippet_suggestion_vote_implemented_path(snippet, suggestion), method: 'post', suggestion_id: suggestion.id } do %>
              <i class="far fa-check"></i>
              <span>Implemented (<%= suggestion.suggestion_votes.where(vote_type: 'implemented').count %>)</span>
            <% end %>
          <% end %>
          <% if not_working_vote %>
            <button class="suggestion-vote-btn flex items-center space-x-1 bg-red-100 text-red-700 px-3 py-1 rounded-full text-sm font-medium transition-colors" data-suggestion-id="<%= suggestion.id %>" data-voted="true" data-url="<%= snippet_suggestion_unvote_path(snippet, suggestion) %>" data-method="delete">
              <i class="fas fa-times"></i>
              <span>Not Working (<%= suggestion.suggestion_votes.where(vote_type: 'not_working').count %>)</span>
            </button>
          <% else %>
            <%= link_to snippet_suggestion_vote_not_working_path(snippet, suggestion), method: :post, class: "suggestion-vote-btn text-gray-500 hover:text-red-500 px-3 py-1 rounded-full text-sm font-medium transition-colors", data: { url: snippet_suggestion_vote_not_working_path(snippet, suggestion), method: 'post', suggestion_id: suggestion.id } do %>
              <i class="far fa-times"></i>
              <span>Not Working (<%= suggestion.suggestion_votes.where(vote_type: 'not_working').count %>)</span>
            <% end %>
          <% end %>
          <button class="text-sm text-blue-600 hover:text-blue-800 font-medium reply-btn transition-colors" data-suggestion-id="<%= suggestion.id %>">Reply</button>
          <div class="reply-form hidden w-full mt-3" data-suggestion-id="<%= suggestion.id %>">
            <%= form_for [snippet, Suggestion.new(response_to: suggestion)], html: { class: "reply-form-ajax" } do |f| %>
              <%= f.text_area :content, placeholder: "Write a reply...", class: "w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent", rows: 3 %>
              <%= f.submit "Post Reply", class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg mt-2 font-medium transition-colors" %>
            <% end %>
          </div>
        <% else %>
          <span class="flex items-center space-x-1 text-gray-500 text-sm"><i class="far fa-thumbs-up"></i><span>Working (<%= suggestion.suggestion_votes.where(vote_type: 'working').count %>)</span></span>
          <span class="flex items-center space-x-1 text-gray-500 text-sm"><i class="far fa-exclamation-triangle"></i><span>Broken (<%= suggestion.suggestion_votes.where(vote_type: 'broken').count %>)</span></span>
          <span class="flex items-center space-x-1 text-gray-500 text-sm"><i class="far fa-check"></i><span>Implemented (<%= suggestion.suggestion_votes.where(vote_type: 'implemented').count %>)</span></span>
          <span class="flex items-center space-x-1 text-gray-500 text-sm"><i class="far fa-times"></i><span>Not Working (<%= suggestion.suggestion_votes.where(vote_type: 'not_working').count %>)</span></span>
        <% end %>
      </div>
    </div>
    <div class="mt-4 space-y-4">
      <% suggestion.responses.each do |response| %>
        <%= render partial: 'suggestions/suggestion', locals: { suggestion: response, snippet: snippet } %>
      <% end %>
    </div>
  </div>