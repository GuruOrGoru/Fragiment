<% if user_signed_in? %>
  <% working_vote = current_user.snippet_votes.find_by(snippet: snippet, vote_type: 'working') %>
  <% broken_vote = current_user.snippet_votes.find_by(snippet: snippet, vote_type: 'broken') %>
  <% if working_vote %>
    <button class="snippet-vote-btn text-green-500 hover:text-green-700 text-sm" data-snippet-id="<%= snippet.id %>" data-voted="true" data-url="<%= snippet_unvote_snippet_path(snippet) %>" data-method="delete">
      <i class="fas fa-check-circle"></i> Working (<%= snippet.snippet_votes.where(vote_type: 'working').count %>)
    </button>
  <% else %>
    <%= link_to snippet_vote_working_path(snippet), method: :post, class: "snippet-vote-btn text-gray-500 hover:text-green-500 text-sm", data: { url: snippet_vote_working_path(snippet), method: 'post', snippet_id: snippet.id } do %>
      <i class="far fa-check-circle"></i> Working (<%= snippet.snippet_votes.where(vote_type: 'working').count %>)
    <% end %>
  <% end %>
  <% if broken_vote %>
    <button class="snippet-vote-btn text-red-500 hover:text-red-700 text-sm" data-snippet-id="<%= snippet.id %>" data-voted="true" data-url="<%= snippet_unvote_snippet_path(snippet) %>" data-method="delete">
      <i class="fas fa-times-circle"></i> Broken (<%= snippet.snippet_votes.where(vote_type: 'broken').count %>)
    </button>
  <% else %>
    <%= link_to snippet_vote_broken_path(snippet), method: :post, class: "snippet-vote-btn text-gray-500 hover:text-red-500 text-sm", data: { url: snippet_vote_broken_path(snippet), method: 'post', snippet_id: snippet.id } do %>
      <i class="far fa-times-circle"></i> Broken (<%= snippet.snippet_votes.where(vote_type: 'broken').count %>)
    <% end %>
  <% end %>
<% else %>
  <span class="text-gray-500 text-sm"><i class="far fa-check-circle"></i> Working (<%= snippet.snippet_votes.where(vote_type: 'working').count %>)</span>
  <span class="text-gray-500 text-sm"><i class="far fa-times-circle"></i> Broken (<%= snippet.snippet_votes.where(vote_type: 'broken').count %>)</span>
<% end %>