<div class="mb-8">
  <h1 class="text-3xl font-bold mb-4"><%= @language %> Snippets</h1>
  <p class="text-gray-600 mb-4">All snippets written in <%= @language %></p>
   <div class="flex space-x-4">
     <%= link_to "View All Snippets", snippets_path, class: "text-blue-500 hover:text-blue-700" %>
   </div>
</div>

<div class="space-y-6">
  <% @snippets.each do |snippet| %>
    <div class="bg-white p-6 rounded-lg shadow-md">
      <div class="flex justify-between items-start mb-4">
        <div>
          <h2 class="text-xl font-semibold mb-1"><%= link_to snippet.title, snippet %></h2>
          <p class="text-gray-600 text-sm">By <%= link_to snippet.user.name, user_path(snippet.user), class: "hover:text-blue-600" %> • <%= snippet.language %></p>
          <% if snippet.tags.any? %>
            <div class="flex flex-wrap gap-1 mt-1">
              <% snippet.tags.each do |tag| %>
                <span class="inline-block bg-gray-200 text-gray-700 text-xs px-2 py-1 rounded"><%= tag.name %></span>
              <% end %>
            </div>
          <% end %>
        </div>
        <div class="flex items-center space-x-4 text-sm text-gray-500">
          <%= render partial: "snippets/bookmark_button", locals: { snippet: snippet } %>
          <%= render partial: "snippets/snippet_vote_buttons", locals: { snippet: snippet } %>
          <%= link_to "#{snippet.suggestions.count} suggestions", snippet, class: "hover:text-blue-600" %>
        </div>
      </div>

      <% if snippet.description.present? %>
        <p class="text-gray-700 mb-4"><%= snippet.description.truncate(150) %></p>
      <% end %>

      <div class="mb-4">
        <div class="bg-gray-800 rounded-t-lg p-3 flex items-center">
          <div class="flex space-x-2">
            <div class="w-3 h-3 bg-red-500 rounded-full"></div>
            <div class="w-3 h-3 bg-yellow-500 rounded-full"></div>
            <div class="w-3 h-3 bg-green-500 rounded-full"></div>
          </div>
          <div class="flex-1 text-center text-white text-sm"><%= snippet.language %></div>
        </div>
        <div class="bg-gray-900 p-4 rounded-b-lg max-h-40 overflow-hidden relative">
          <pre class="text-green-400 text-sm"><code><%= format_code(snippet.code.truncate(150), snippet.language) %></code></pre>
          <% if snippet.code.length > 150 %>
            <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-gray-900 to-transparent p-4 pt-8">
              <span class="text-green-400">...</span>
              <%= link_to "view more", snippet, class: "ml-2 text-blue-400 hover:text-blue-300 text-sm" %>
            </div>
          <% end %>
        </div>
      </div>

       <% if snippet.image.attached? %>
         <div class="mb-4">
           <% if snippet.image.content_type == 'image/svg+xml' %>
             <div class="w-full max-w-md h-48 rounded overflow-hidden">
               <object data="<%= url_for(snippet.image) %>" type="image/svg+xml" class="w-full h-full object-cover"></object>
             </div>
           <% else %>
             <%= image_tag snippet.image.variant(:thumb), class: "w-full max-w-md h-48 object-cover rounded" %>
           <% end %>
         </div>
      <% end %>

      <% if snippet.video.attached? %>
        <div class="mb-4">
          <video controls class="w-full max-w-md rounded">
            <%= video_tag snippet.video, controls: true %>
          </video>
        </div>
      <% end %>

       <div class="flex items-center justify-end mt-4">
         <button class="text-gray-500 hover:text-blue-500 share-btn" data-url="<%= snippet_url(snippet) %>">
           <i class="fas fa-share"></i> Share
         </button>
       </div>
    </div>
  <% end %>
</div>

<div class="mt-8">
  <%= paginate @snippets %>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Handle share buttons
  document.querySelectorAll('.share-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      const url = this.dataset.url;
      navigator.clipboard.writeText(url).then(function() {
        // Show temporary feedback
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-check"></i> Copied!';
        btn.classList.add('text-green-500');
        setTimeout(function() {
          btn.innerHTML = originalText;
          btn.classList.remove('text-green-500');
        }, 2000);
      });
    });
  });
});
</script>

<script type="module">
  import "./channels/snippet_channel"
</script>