// Update snippet vote buttons
document.querySelectorAll('[data-snippet-id="<%= @snippet.id %>"]').forEach(function(container) {
  var workingBtn = container.querySelector('.fa-check-circle');
  var brokenBtn = container.querySelector('.fa-times-circle');

  if (workingBtn) {
    workingBtn = workingBtn.closest('button, a');
    if ('<%= @vote.vote_type %>' === 'working') {
      workingBtn.innerHTML = '<i class="fas fa-check-circle"></i> Working (<%= @snippet.snippet_votes.where(vote_type: 'working').count %>)';
      workingBtn.className = 'snippet-vote-btn text-green-500 hover:text-green-700 text-sm';
      workingBtn.setAttribute('data-url', '<%= snippet_unvote_snippet_path(@snippet) %>');
      workingBtn.setAttribute('data-method', 'delete');
    } else {
      workingBtn.innerHTML = '<i class="far fa-check-circle"></i> Working (<%= @snippet.snippet_votes.where(vote_type: 'working').count %>)';
    }
  }

  if (brokenBtn) {
    brokenBtn = brokenBtn.closest('button, a');
    if ('<%= @vote.vote_type %>' === 'broken') {
      brokenBtn.innerHTML = '<i class="fas fa-times-circle"></i> Broken (<%= @snippet.snippet_votes.where(vote_type: 'broken').count %>)';
      brokenBtn.className = 'snippet-vote-btn text-red-500 hover:text-red-700 text-sm';
      brokenBtn.setAttribute('data-url', '<%= snippet_unvote_snippet_path(@snippet) %>');
      brokenBtn.setAttribute('data-method', 'delete');
    } else {
      brokenBtn.innerHTML = '<i class="far fa-times-circle"></i> Broken (<%= @snippet.snippet_votes.where(vote_type: 'broken').count %>)';
    }
  }
});