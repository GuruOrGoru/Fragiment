<div class="max-w-2xl mx-auto">
  <h1 class="text-3xl font-bold mb-6">Edit Profile</h1>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, multipart: true, class: "space-y-6" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="bg-white p-6 rounded-lg shadow-md">
      <h2 class="text-xl font-semibold mb-4">Account Information</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "w-full p-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>

        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, autocomplete: "email", class: "w-full p-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="mt-4 p-3 bg-yellow-100 border border-yellow-400 text-yellow-700 rounded">
          Currently waiting confirmation for: <%= resource.unconfirmed_email %>
        </div>
      <% end %>
    </div>

    <div class="bg-white p-6 rounded-lg shadow-md">
      <h2 class="text-xl font-semibold mb-4">Change Password</h2>
      <p class="text-sm text-gray-600 mb-4">Leave blank if you don't want to change it</p>

       <div>
         <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
         <%= f.password_field :password, autocomplete: "new-password", class: "w-full p-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500" %>
         <% if @minimum_password_length %>
           <p class="text-xs text-gray-500 mt-1"><%= @minimum_password_length %> characters minimum</p>
         <% end %>
       </div>
    </div>

    <div class="bg-white p-6 rounded-lg shadow-md">
      <h2 class="text-xl font-semibold mb-4">Profile Information</h2>

      <div class="mb-4">
        <%= f.label :avatar, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <div class="flex items-center space-x-4">
           <% if current_user.avatar.attached? %>
             <div class="flex-shrink-0">
               <% if current_user.avatar.content_type == 'image/svg+xml' %>
                 <div class="w-20 h-20 rounded-full border-2 border-gray-200 overflow-hidden">
                   <object data="<%= url_for(current_user.avatar) %>" type="image/svg+xml" class="w-full h-full"></object>
                 </div>
               <% else %>
                 <%= image_tag current_user.avatar.variant(:thumb), class: "w-20 h-20 rounded-full object-cover border-2 border-gray-200" %>
               <% end %>
             </div>
          <% else %>
            <div class="w-20 h-20 bg-gray-300 rounded-full flex items-center justify-center border-2 border-gray-200">
              <span class="text-2xl font-medium text-gray-700"><%= current_user.name[0].upcase %></span>
            </div>
          <% end %>
          <div class="flex-1">
            <%= f.file_field :avatar, accept: "image/png,image/jpeg,image/gif,image/webp", class: "w-full p-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500" %>
            <p class="text-xs text-gray-500 mt-1">Upload a profile picture (PNG, JPG, GIF, WebP)</p>
          </div>
        </div>
      </div>

      <div class="mb-4">
        <%= f.label :bio, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :bio, rows: 4, placeholder: "Tell us about yourself...", class: "w-full p-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div class="mb-4">
        <%= f.label :favorite_languages, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :favorite_languages, placeholder: "e.g. Ruby, JavaScript, Python", class: "w-full p-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>
    </div>





     <div class="flex justify-end space-x-4">
       <%= link_to "Back to Profile", user_path(current_user), class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600" %>
       <%= f.submit "Update Profile", class: "bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600" %>
     </div>
   <% end %>
 </div>

 <div class="mt-8 bg-red-50 p-6 rounded-lg border border-red-200">
   <div class="flex justify-between items-center">
     <div>
       <h3 class="text-lg font-medium text-red-800">Danger Zone</h3>
       <p class="text-sm text-red-600">Unhappy with your account?</p>
     </div>
     <%= button_to "Cancel my account", registration_path(resource_name), data: { confirm: "Are you sure you want to delete your account? This action cannot be undone.", turbo_confirm: "Are you sure you want to delete your account? This action cannot be undone." }, method: :delete, class: "bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600" %>
   </div>
 </div>


